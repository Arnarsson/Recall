# Recall App Configuration
# Copy this file to .env and fill in your values

# WindRecorder Settings
WINDRECORDER_DB_PATH=~/WindRecorder/userdata/db
MAX_SIZE_MB=5000
MAX_AGE_DAYS=30

# Hetzner Server Settings
HETZNER_HOST=your-server.hetzner.com
HETZNER_USER=backup-user
SSH_KEY_PATH=~/.ssh/id_rsa
REMOTE_BACKUP_DIR=/var/backups/windrecorder

# Claude Logs
CLAUDE_LOG_PATH=~/.claude/projects

# Local Storage
CHROMA_DB_PATH=~/Library/Application Support/Recall/chroma_db
APP_DATA_DIR=~/Library/Application Support/Recall

# Search Settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
SEARCH_THRESHOLD=0.3
SEARCH_LIMIT=50

# UI Settings
NOTIFICATION_ENABLED=true
AUTO_ARCHIVE=true
TIMELINE_HOURS=24

# Debug Settings
LOG_LEVEL=INFO
DEBUG_MODE=false